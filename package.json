{
  "name": "heart-message",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev:client": "pnpm --filter @heart-message/client dev:web",
    "dev:admin": "pnpm --filter @heart-message/admin dev",
    "dev:api": "pnpm --filter @heart-message/api dev",
    "build": "pnpm -r build",
    "deploy:ci": "pnpm --filter @heart-message/api deploy:ci",
    "deploy:api:ci": "pnpm --filter @heart-message/api deploy:ci",
    "typecheck": "pnpm -r typecheck",
    "openspec": "openspec",
    "spec:status": "node scripts/openspec-status.mjs",
    "spec:validate": "openspec validate --all --strict --no-interactive",
    "spec:update": "openspec update"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.5.0",
    "typescript": "^6.0.3"
  }
}
