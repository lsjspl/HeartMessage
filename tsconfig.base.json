{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@heart-message/shared": ["packages/shared/src/index.ts"],
      "@heart-message/db": ["packages/db/src/index.ts"],
      "@heart-message/ai": ["packages/ai/src/index.ts"]
    }
  }
}
